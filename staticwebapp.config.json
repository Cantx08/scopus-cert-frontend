{
  "routes": [
    {
      "route": "/login",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "allowedRoles": ["di_prueba2"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "ALLOW-FROM https://epnecuador.sharepoint.com",
    "Content-Security-Policy": "frame-ancestors 'self' https://epnecuador.sharepoint.com"
  }
}